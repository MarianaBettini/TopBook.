<!-- client/index.html -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!--[cite: 2] -->
    <title>Sistema de Biblioteca - PPI</title>
    <link rel="stylesheet" href="styles.css"> <!--[cite: 2] -->
</head>
<body>
    <header>
        <h1>Biblioteca Universitária - Controle de Empréstimos</h1>
    </header>
    
    <main class="container">
        <!-- Formulário de Entrada de Dados -->
        <section class="formulario-box">
            <h2>Registrar Novo Empréstimo</h2>
            <form id="formCadastro">
                <label for="txtTitulo">Título do Livro:</label>
                <input type="text" id="txtTitulo" required placeholder="Ex: O Alquimista">

                <label for="txtAutor">Autor:</label>
                <input type="text" id="txtAutor" required placeholder="Ex: Paulo Coelho">

                <label for="txtEstudante">Estudante:</label>
                <input type="text" id="txtEstudante" required placeholder="Nome do aluno">

                <label for="selStatus">Status Inicial:</label>
                <select id="selStatus" required>
                    <option value="Emprestado">Emprestado</option>
                    <option value="Disponível">Disponível</option>
                </select>

                <button type="submit">Confirmar Registro</button>
            </form>
        </section>

        <!-- Container de Renderização Dinâmica -->
        <section class="listagem-box">
            <h2>Livros Cadastrados e Movimentações</h2>
            <div id="listaContainer" class="lista-grid">
                <!-- Inserido via TypeScript dinamicamente --> <!--[cite: 2] -->
                <p class="aviso-vazio">Carregando acervo local...</p>
            </div>
        </section>
    </main>

    <!-- O navegador consome o arquivo compilado em JAVASCRIPT (.js) --> <!--[cite: 2] -->
    <script src="app.js"></script>
</body>
</html>