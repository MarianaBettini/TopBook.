// client/app.ts

const URL_API = 'http://localhost:3000/livros';

// Mapeamento explícito de elementos do DOM com asserção de tipos correta[cite: 2]
const form = document.getElementById('formCadastro') as HTMLFormElement;
const inputTitulo = document.getElementById('txtTitulo') as HTMLInputElement;
const inputAutor = document.getElementById('txtAutor') as HTMLInputElement;
const inputEstudante = document.getElementById('txtEstudante') as HTMLInputElement;
const selectStatus = document.getElementById('selStatus') as HTMLSelectElement;
const listaContainer = document.getElementById('listaContainer') as HTMLDivElement;

// FUNÇÃO ASSÍNCRONA: Buscar livros da API e renderizar na tela[cite: 1, 2]
async function carregarElementos(): Promise<void> {
    try {
        const resposta = await fetch(URL_API); //[cite: 2]
        if (!resposta.ok) throw new Error("Erro ao conectar na API de listagem."); //[cite: 2]
        
        // Definição estrita do tipo recebido da API (Evitando o tipo any)
        const dados: any[] = await resposta.json(); 
        
        listaContainer.innerHTML = ""; // Limpa o aviso de carregamento[cite: 2]

        if (dados.length === 0) {
            listaContainer.innerHTML = "<p>Nenhum livro registrado no momento.</p>";
            return;
        }

        // Mapeamento estruturado e criação dinâmica de elementos[cite: 2]
        dados.forEach((item: any) => {
            const card = document.createElement('div');
            card.className = `card-item ${item.status.toLowerCase()}`;
            
            card.innerHTML = `
                <h3>${item.titulo}</h3>
                <p><strong>Autor:</strong> ${item.autor}</p>
                <p><strong>Alocado para:</strong> ${item.estudante}</p>
                <span class="badge">${item.status}</span>
                <br>
                <small>Registrado em: ${new Date(item.dataEmprestimo).toLocaleString()}</small>
            `;
            listaContainer.appendChild(card);
        });
    } catch (erro) {
        console.error("[ERRO FRONT]", erro); //[cite: 2]
        listaContainer.innerHTML = "<p style='color:red;'>Erro de rede ao buscar acervo.</p>";
    }
}

// EVENTO DE SUBMISSÃO DO FORMULÁRIO[cite: 2]
form.addEventListener('submit', async (evento: SubmitEvent) => {
    evento.preventDefault(); // Impede o recarregamento clássico da página[cite: 2]

    const cargaUtil = {
        titulo: inputTitulo.value.trim(),
        autor: inputAutor.value.trim(),
        estudante: inputEstudante.value.trim(),
        status: selectStatus.value
    };

    try {
        const resposta = await fetch(URL_API, {
            method: 'POST', //[cite: 2]
            headers: { 'Content-Type': 'application/json' }, //[cite: 2]
            body: JSON.stringify(cargaUtil) // Transforma o objeto em string JSON[cite: 2]
        });

        if (resposta.status === 201) {
            form.reset(); // Limpa os campos do formulário[cite: 2]
            await carregarElementos(); // Atualiza a lista automaticamente na tela[cite: 2]
        } else {
            alert("Falha ao registrar livro no servidor."); //[cite: 2]
        }
    } catch (erro) {
        alert("Servidor offline ou falha de rede."); //[cite: 2]
    }
});

// DISPARO AUTOMÁTICO INICIAL AO ABRIR O NAVEGADOR[cite: 2]
carregarElementos();