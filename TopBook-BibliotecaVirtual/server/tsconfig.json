{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": ".",
    // Removi a linha "outDir": "./dist" para o JS nascer na mesma pasta do TS
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}